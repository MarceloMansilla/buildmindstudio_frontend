{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pnpm run *)",
      "Bash(pnpm install)",
      "Bash(pnpm dlx *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | *)",
      "Bash(wget * | *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(python -c *)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(/input/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [".next/**", "node_modules/.cache/**"],
      "allowRead": ["."],
      "denyRead": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.anthropic", "~/.npmrc", "~/.config"]
    },
    "network": {
      "allowedDomains": ["api.anthropic.com", "registry.npmjs.org"]
    }
  }
}
